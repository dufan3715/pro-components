      "type": "function",
      "name": "ProTable",
      "filePath": "packages/antd-vue-pro/src/components/table/components/BaseTable.vue",
      "lineRange": [1, 331],
      "summary": "配置驱动 Pro 表格组件，集成搜索表单（SearchForm）、分页状态管理、列显隐控制（ColumnControl）、尺寸切换（SizeControl）、序号列自动注入、双向绑定 loading/size、全局配置注入及完整的插槽系统（search-form/button-bar/toolbar/table/bodyCell），通过 useTable hook 驱动数据查询流程。",
      "tags": ["table", "search-filter", "column-control", "pagination", "data-display"],
      "complexity": "complex"
    }
