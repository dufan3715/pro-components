    {
      "id": "file:packages/antdv-next-pro/src/components/form/types/index.ts",
      "type": "file",
      "name": "index.ts",
      "filePath": "packages/antdv-next-pro/src/components/form/types/index.ts",
      "summary": "表单字段系统的核心类型定义文件，定义了 Field、Fields、Base、FieldTypeMap、WithRef 等关键类型，支持字段配置的响应式属性、嵌套字段、自定义组件以及完整的插槽与容器系统。",
      "tags": ["type-definition", "form", "字段配置", "vue", "泛型"],
      "complexity": "complex",
      "languageNotes": "通过 discriminated union 将带嵌套字段（BaseWithFields）与无嵌套字段（BaseWithoutFields）配置区分，WithRef<T> 为绝大部分属性添加 MaybeRef 响应式支持，排除 component、valueFormatter 等特殊属性。"
    },
