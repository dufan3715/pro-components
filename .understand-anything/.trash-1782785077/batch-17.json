      "name": "ContainerFragment",
      "filePath": "packages/antdv-next-pro/src/components/form/components/ContainerFragment/index.vue",
      "summary": "容器分片渲染组件，根据 component prop 动态渲染外层包裹容器（如 Grid 行、Col 列等布局容器），无组件传入时直接透传默认插槽。",
      "tags": ["layout-container", "dynamic-rendering", "slot-wrapper", "vue-sfc"],
      "complexity": "simple"
    },
    {
