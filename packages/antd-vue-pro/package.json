{
  "name": "@qin-ui/antd-vue-pro",
  "version": "2.2.0",
  "description": "二次封装antd vue组件",
  "bin": {
    "antd-vue-pro": "./bin/init-ai.mjs"
  },
  "type": "module",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "main": "es/index.js",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js"
    },
    "./antd-vue-pro.css": "./es/antd-vue-pro.css"
  },
  "files": [
    "es",
    "src",
    "bin",
    "README.md",
    "LICENSE",
    "api.json",
    "AI-CONTEXT.md"
  ],
  "homepage": "https://dufan3715.github.io/pro-components/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dufan3715/pro-components.git"
  },
  "scripts": {
    "prebuild": "tsx ../../scripts/generate-api-json.ts antd-vue-pro",
    "build": "vue-tsc --noEmit && vite build",
    "prepublishOnly": "pnpm build"
  },
  "author": "dufan3715",
  "bugs": {
    "url": "https://github.com/dufan3715/pro-components/issues"
  },
  "license": "MIT",
  "private": false,
  "peerDependencies": {
    "ant-design-vue": "^4",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@qin-ui/pro-components-core": "workspace:^",
    "scroll-into-view-if-needed": "^3.1.0"
  },
  "devDependencies": {
    "ant-design-vue": "^4",
    "vue-component-type-helpers": "^3.2.5"
  },
  "sideEffects": [
    "**/*.css",
    "./es/index.js"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vue",
    "antd",
    "ant-design-vue",
    "antd-vue-pro",
    "pro-components",
    "ui",
    "form",
    "table",
    "pro-form",
    "pro-table"
  ]
}
