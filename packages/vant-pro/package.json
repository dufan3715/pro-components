{
  "name": "@qin-ui/vant-pro",
  "version": "1.1.1",
  "description": "基于 vant 和 @qin-ui/pro-components-core 封装的高级表单和列表组件库",
  "bin": {
    "vant-pro": "./bin/init-ai.mjs"
  },
  "type": "module",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "main": "es/index.js",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js"
    }
  },
  "files": [
    "es",
    "src",
    "bin",
    "README.md",
    "LICENSE",
    "api.json",
    "AI-CONTEXT.md"
  ],
  "homepage": "https://dufan3715.github.io/pro-components/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dufan3715/pro-components.git"
  },
  "scripts": {
    "prebuild": "tsx ../../scripts/generate-api-json.ts vant-pro",
    "build": "vue-tsc --noEmit && vite build",
    "prepublishOnly": "pnpm build"
  },
  "author": "dufan3715",
  "bugs": {
    "url": "https://github.com/dufan3715/pro-components/issues"
  },
  "license": "MIT",
  "private": false,
  "peerDependencies": {
    "vant": "^4.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@qin-ui/pro-components-core": "workspace:^"
  },
  "devDependencies": {
    "vant": "^4.9.15",
    "vue-component-type-helpers": "^3.2.5"
  },
  "sideEffects": [
    "**/*.css",
    "./es/index.js"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vue",
    "vant",
    "vant-pro",
    "pro-components",
    "ui",
    "form",
    "pro-form"
  ]
}
