{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./es",
    "emitDeclarationOnly": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "outDir": "./es",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": ["node_modules", "es"]
}
